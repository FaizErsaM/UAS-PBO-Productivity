rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'title', 'deadline', 'completed', 'priority'])
        && data.keys().size() <= 10
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.deadline is string && data.deadline.size() <= 128
        && data.completed is bool
        && data.priority is string && (data.priority == 'high' || data.priority == 'medium' || data.priority == 'low');
    }

    function isValidHabit(data) {
      return data.keys().hasAll(['id', 'title', 'progress', 'goal', 'unit'])
        && data.keys().size() <= 10
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.progress is int
        && data.goal is int
        && data.unit is string && data.unit.size() <= 50;
    }

    // User Profile
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && incoming().keys().hasAll(['uid', 'email']) && incoming().uid == userId;
      allow delete: if isOwner(userId);

      // Tasks Subcollection
      match /tasks/{taskId} {
        allow get: if isOwner(userId) && isValidId(taskId);
        allow list: if isOwner(userId);
        
        allow create: if isOwner(userId) && isValidId(taskId) 
          && isValidTask(incoming())
          && incoming().id == taskId;

        allow update: if isOwner(userId) && isValidId(taskId)
          && isValidTask(incoming())
          && incoming().id == existing().id;

        allow delete: if isOwner(userId) && isValidId(taskId);
      }

      // Habits Subcollection
      match /habits/{habitId} {
        allow get: if isOwner(userId) && isValidId(habitId);
        allow list: if isOwner(userId);
        
        allow create: if isOwner(userId) && isValidId(habitId) 
          && isValidHabit(incoming())
          && incoming().id == habitId;

        allow update: if isOwner(userId) && isValidId(habitId)
          && isValidHabit(incoming())
          && incoming().id == existing().id;

        allow delete: if isOwner(userId) && isValidId(habitId);
      }
    }
  }
}
