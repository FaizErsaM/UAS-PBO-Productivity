{
  "entities": {
    "user": {
      "title": "User",
      "description": "Represents a user profile in the system",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "Primary email address" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of account creation" }
      },
      "required": ["uid", "email"]
    },
    "task": {
      "title": "Task",
      "description": "A task or assignment with deadlining",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique task ID" },
        "title": { "type": "string", "description": "Task title" },
        "course": { "type": "string", "description": "Course code or name" },
        "deadline": { "type": "string", "format": "date-time", "description": "Task deadline" },
        "completed": { "type": "boolean", "description": "True if completed" },
        "priority": { "type": "string", "enum": ["high", "medium", "low"], "description": "Urgency degree" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["id", "title", "deadline", "completed", "priority"]
    },
    "habit": {
      "title": "Habit",
      "description": "A positive routine tracked daily",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique habit ID" },
        "title": { "type": "string", "description": "Routine title" },
        "progress": { "type": "integer", "description": "Completed progress value" },
        "goal": { "type": "integer", "description": "Target completion goal value" },
        "unit": { "type": "string", "description": "Goal tracking unit, e.g. days" },
        "category": { "type": "string", "description": "Classification category, e.g. Productivity" },
        "lastCompletedDate": { "type": "string", "description": "Date of the last tick" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["id", "title", "progress", "goal", "unit"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "user",
      "description": "User profile collection"
    },
    "users/{userId}/tasks/{taskId}": {
      "schema": "task",
      "description": "User specific tasks list"
    },
    "users/{userId}/habits/{habitId}": {
      "schema": "habit",
      "description": "User specific daily habits list"
    }
  }
}
